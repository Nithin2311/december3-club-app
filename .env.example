# December3.club environment. Copy to .env and fill real values:
#   cp .env.example .env   &&   make gen-secrets
# NEVER commit .env.

# ---- Site / proxy ----
# Dev: ":80" (plain HTTP, localhost). Prod: "december3.club" (Caddy auto-TLS).
SITE_ADDRESS=:80
ACME_EMAIL=you@example.com
NEXT_PUBLIC_SITE_URL=http://localhost

# ---- Database ----
POSTGRES_PASSWORD=change-me-run-make-gen-secrets

# ---- Auth / sessions ----
SESSION_SECRET=change-me-run-make-gen-secrets
COOKIE_SECURE=true
CORS_ORIGINS=http://localhost

# ---- LLM provider (Google Gemini) ----
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
